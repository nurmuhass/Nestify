{
  "expo": {
    "name": "Nestify",
    "slug": "nestify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nestify",
    "userInterfaceStyle": "dark",
    "owner": "nurmuhass2",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nurmuhass.nestify"
    },
    "android": {
      "package": "com.nurmuhass.nestify",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "NOTIFICATIONS",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#06122C"
      },
      "statusBar": {
        "backgroundColor": "#06122C",
        "barStyle": "light-content"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "cover",
          "backgroundColor": "#06122C",
          "dark": {
            "backgroundColor": "#06122C"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#C9A84C",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f123d644-7d1f-4183-a5d9-7624d36edba1"
      }
    }
  }
}